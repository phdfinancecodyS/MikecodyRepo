# Copy these into Railway → your service → Variables tab
# (never commit the actual .env file)

CCE_LLM_PROVIDER=groq
CCE_LLM_API_KEY=your-groq-api-key-here
CCE_LLM_API_KEY_GROQ=your-groq-api-key-here
CCE_RESPONSE_ENGINE=llm
CCE_TOPIC_ENGINE=llm
CCE_SENTIMENT_ENGINE=llm

# Set to your Railway public URL (find it in your service's Settings → Networking)
# Example: https://my-app.up.railway.app
CCE_CORS_ORIGINS=https://YOUR-APP.up.railway.app
