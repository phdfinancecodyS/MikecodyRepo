{
  "version": 1,
  "name": "audience_bucket_lens_matcher",
  "description": "Optional audience-lens matcher that helps the platform recommend the most resonant version of a guide.",
  "entryRules": {
    "showAfterTopicMatcher": true,
    "appliesToRiskLevels": ["low_risk", "moderate_risk", "high_risk"],
    "criticalBehavior": "skip_audience_matcher_show_crisis_resources"
  },
  "selectionRules": {
    "maxSelectionsIdentity": 2,
    "maxSelectionsContext": 2,
    "allowNoSelection": true,
    "primaryBucketRequiredIfMultiSelected": true,
    "maxOverlayBuckets": 2,
    "fallbackBucket": "general-mental-health"
  },
  "buckets": [
    { "id": "christian", "label": "Christian", "tier": "primary", "group": "identity" },
    { "id": "military-veteran", "label": "Military / Veteran", "tier": "primary", "group": "identity" },
    { "id": "first-responder", "label": "First Responder", "tier": "primary", "group": "identity" },
    { "id": "lgbtq", "label": "LGBTQ+", "tier": "primary", "group": "identity" },
    { "id": "neurodivergent", "label": "Neurodivergent", "tier": "primary", "group": "identity" },
    { "id": "bipoc-racial-trauma", "label": "BIPOC / Racial Trauma", "tier": "overlay", "group": "identity" },
    { "id": "young-adult-gen-z", "label": "Young Adult / Gen Z", "tier": "primary", "group": "identity" },
    { "id": "single-parent", "label": "Single Parent", "tier": "primary", "group": "context" },
    { "id": "healthcare-workers", "label": "Healthcare Workers", "tier": "primary", "group": "context" },
    { "id": "educators", "label": "Educators", "tier": "primary", "group": "context" },
    { "id": "social-workers-counselors", "label": "Social Workers / Counselors", "tier": "overlay", "group": "context" },
    { "id": "high-stress-jobs", "label": "High Stress Jobs", "tier": "overlay", "group": "context" },
    { "id": "addiction-recovery", "label": "Addiction / Recovery", "tier": "primary", "group": "context" },
    { "id": "grief-loss", "label": "Grief / Loss", "tier": "primary", "group": "context" },
    { "id": "chronic-illness-chronic-pain", "label": "Chronic Illness / Chronic Pain", "tier": "overlay", "group": "context" },
    { "id": "faith-beyond-christian", "label": "Faith Beyond Christian", "tier": "overlay", "group": "context" },
    { "id": "general-mental-health", "label": "Keep it general", "tier": "fallback", "group": "fallback" }
  ],
  "questions": [
    {
      "id": "ab_q1",
      "type": "multi_select_max_2",
      "prompt": "Which lens would make this feel most like it was written for you?",
      "options": [
        { "id": "christian", "label": "Christian" },
        { "id": "military-veteran", "label": "Military / Veteran" },
        { "id": "first-responder", "label": "First Responder" },
        { "id": "lgbtq", "label": "LGBTQ+" },
        { "id": "neurodivergent", "label": "Neurodivergent" },
        { "id": "bipoc-racial-trauma", "label": "BIPOC / Racial Trauma" },
        { "id": "young-adult-gen-z", "label": "Young Adult / Gen Z" },
        { "id": "general-mental-health", "label": "Keep it general" }
      ]
    },
    {
      "id": "ab_q2",
      "type": "multi_select_max_2",
      "prompt": "What part of your life is shaping this most right now?",
      "options": [
        { "id": "single-parent", "label": "Single Parent" },
        { "id": "healthcare-workers", "label": "Healthcare Worker" },
        { "id": "educators", "label": "Educator" },
        { "id": "social-workers-counselors", "label": "Social Worker / Counselor" },
        { "id": "high-stress-jobs", "label": "High Stress Job" },
        { "id": "addiction-recovery", "label": "Addiction / Recovery" },
        { "id": "grief-loss", "label": "Grief / Loss" },
        { "id": "chronic-illness-chronic-pain", "label": "Chronic Illness / Chronic Pain" },
        { "id": "faith-beyond-christian", "label": "Faith Beyond Christian" },
        { "id": "general-mental-health", "label": "Keep it general" }
      ]
    },
    {
      "id": "ab_q3",
      "type": "single_select_dynamic",
      "displayRule": "show_if_selected_bucket_count_greater_than_1",
      "prompt": "If we tailor this for you, which one should lead?",
      "source": "selected_options_from_ab_q1_and_ab_q2"
    }
  ],
  "routingRules": {
    "preferSpecificOccupationOverBroad": true,
    "preferExplicitPrimarySelection": true,
    "ifNoSelectionUseFallback": true,
    "maxOverlayBuckets": 2
  },
  "analytics": {
    "events": [
      "audience_bucket_matcher_started",
      "audience_bucket_question_answered",
      "audience_bucket_matcher_completed",
      "audience_primary_bucket_selected",
      "audience_overlay_bucket_selected"
    ],
    "payload": [
      "risk_level",
      "selected_bucket_ids",
      "primary_bucket_id",
      "overlay_bucket_ids",
      "utm_source",
      "utm_medium",
      "utm_campaign",
      "timestamp"
    ]
  }
}