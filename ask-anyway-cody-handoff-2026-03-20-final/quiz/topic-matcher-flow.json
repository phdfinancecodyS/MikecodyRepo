{
  "version": 1,
  "name": "what_topic_do_i_need_matcher",
  "description": "Post-quiz questionnaire that matches users to topic offers and pricing lanes.",
  "pricingProfiles": {
    "hub_spoke_default": {
      "guide": { "label": "Guide", "price": 2, "currency": "USD", "billing": "one_time" },
      "kit": { "label": "Kit", "price": 5, "currency": "USD", "billing": "one_time" },
      "sms": { "label": "Check On Me", "price": 5, "currency": "USD", "billing": "monthly" },
      "bundle": { "label": "Topic Bundle", "price": 10, "currency": "USD", "billing": "one_time_plus_sms_option" }
    },
    "legacy_quiz_launch": {
      "guide": { "label": "How to Help Guide", "price": 10, "currency": "USD", "billing": "one_time" },
      "kit": { "label": "Crisis Kit", "price": 5, "currency": "USD", "billing": "one_time" },
      "sms": { "label": "Check On Me", "price": 4.99, "currency": "USD", "billing": "monthly" }
    }
  },
  "activePricingProfile": "hub_spoke_default",
  "entryRules": {
    "showAfterQuiz": true,
    "appliesToRiskLevels": ["low_risk", "moderate_risk", "high_risk"],
    "criticalBehavior": "skip_matcher_show_crisis_resources"
  },
  "questions": [
    {
      "id": "tm_q1",
      "type": "single_select",
      "prompt": "What do you need most right now?",
      "options": [
        { "id": "calm_nervous_system", "label": "Calm my mind/body and stop spiraling", "weights": { "nervous_system_mood_cognition": 3, "sleep_body_pain_substances": 2 } },
        { "id": "improve_relationships", "label": "Handle conflict at home and communicate better", "weights": { "relationships_family_parenting": 3, "intimacy_sex_connection": 2 } },
        { "id": "process_moral_pain", "label": "Work through guilt, shame, or moral injury", "weights": { "moral_injury_guilt_shame_spirituality": 3 } },
        { "id": "rebuild_identity", "label": "Rebuild purpose, identity, and connection", "weights": { "work_identity_transition": 3 } },
        { "id": "break_habit_loops", "label": "Break coping habits I feel stuck in", "weights": { "dopamine_habits_addictions": 3, "sleep_body_pain_substances": 1 } }
      ]
    },
    {
      "id": "tm_q2",
      "type": "single_select",
      "prompt": "Which situation sounds most like your week?",
      "options": [
        { "id": "short_fuse_numb", "label": "Short fuse, then shut down, then regret", "topicHints": ["ch02", "ch04", "ch23"] },
        { "id": "cant_sleep_overthink", "label": "Can't switch off, bad sleep, wired and tired", "topicHints": ["ch05", "ch13", "ch15"] },
        { "id": "relationship_minefield", "label": "Home feels tense and conversations go sideways", "topicHints": ["ch21", "ch22", "ch23"] },
        { "id": "isolated_purpose", "label": "I feel alone and disconnected from purpose", "topicHints": ["ch41", "ch42", "ch45"] },
        { "id": "numbing_coping", "label": "I keep numbing out with habits or substances", "topicHints": ["ch18", "ch32", "ch47"] }
      ]
    },
    {
      "id": "tm_q3",
      "type": "multi_select_max_2",
      "prompt": "Pick up to 2 outcomes you want next.",
      "options": [
        { "id": "better_conversations", "label": "Better conversations this week", "offerBias": "guide" },
        { "id": "step_by_step_plan", "label": "A step-by-step plan for hard moments", "offerBias": "kit" },
        { "id": "weekly_accountability", "label": "Weekly check-ins so I don't drift", "offerBias": "sms" },
        { "id": "all_in_one", "label": "Give me the full stack and keep it simple", "offerBias": "bundle" }
      ]
    }
  ],
  "scoring": {
    "domainSelectionMethod": "weighted_plus_topic_hints",
    "topicSelectionMethod": "top_3_by_match",
    "tieBreaker": "prefer_topic_hints_from_tm_q2"
  },
  "recommendationRules": {
    "defaultResultCount": 3,
    "includeDomainLabel": true,
    "includeWhyMatched": true,
    "highRiskOverride": {
      "enabled": true,
      "action": "prepend_crisis_resources_then_show_topic_recommendations"
    }
  },
  "offerMapping": {
    "guide": {
      "description": "1 focused topic guide to get moving today",
      "cta": "Get My Topic Guide"
    },
    "kit": {
      "description": "tools + scripts + worksheet set for this topic cluster",
      "cta": "Get My Topic Kit"
    },
    "sms": {
      "description": "weekly text nudges and accountability",
      "cta": "Start Check On Me"
    },
    "bundle": {
      "description": "top 3 matched topics + practical toolkit + optional SMS",
      "cta": "Get My Recommended Bundle"
    }
  },
  "analytics": {
    "events": [
      "topic_matcher_started",
      "topic_matcher_question_answered",
      "topic_matcher_completed",
      "topic_recommendation_viewed",
      "topic_offer_clicked",
      "topic_offer_purchased"
    ],
    "payload": [
      "risk_level",
      "selected_domain",
      "recommended_topic_ids",
      "recommended_offer_type",
      "utm_source",
      "utm_medium",
      "utm_campaign",
      "timestamp"
    ]
  },
  "complianceRules": [
    "Do not gate crisis resources behind purchase or capture.",
    "For high_risk users, always show crisis options first.",
    "Use non-diagnostic plain language in question prompts and result copy."
  ]
}
